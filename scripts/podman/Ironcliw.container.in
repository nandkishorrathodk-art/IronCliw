# Ironcliw gateway — Podman Quadlet (rootless)
# Installed by setup-podman.sh into Ironcliw's ~/.config/containers/systemd/
# {{IRONCLIW_HOME}} is replaced at install time.

[Unit]
Description=Ironcliw gateway (rootless Podman)

[Container]
Image=Ironcliw:local
ContainerName=Ironcliw
UserNS=keep-id
# Keep container UID/GID aligned with the invoking user so mounted config is readable.
User=%U:%G
Volume={{IRONCLIW_HOME}}/.Ironcliw:/home/node/.Ironcliw
EnvironmentFile={{IRONCLIW_HOME}}/.Ironcliw/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
PublishPort=18789:18789
PublishPort=18790:18790
Pull=never
Exec=node dist/index.js gateway --bind lan --port 18789

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target

