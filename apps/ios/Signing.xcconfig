// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

IRONCLIW_CODE_SIGN_STYLE = Manual
IRONCLIW_DEVELOPMENT_TEAM = Y5PE65HELJ

IRONCLIW_APP_BUNDLE_ID = ai.ironcliw.client
IRONCLIW_SHARE_BUNDLE_ID = ai.ironcliw.client.share
IRONCLIW_WATCH_APP_BUNDLE_ID = ai.ironcliw.client.watchkitapp
IRONCLIW_WATCH_EXTENSION_BUNDLE_ID = ai.ironcliw.client.watchkitapp.extension
IRONCLIW_ACTIVITY_WIDGET_BUNDLE_ID = ai.ironcliw.client.activitywidget

IRONCLIW_APP_PROFILE = ai.ironcliw.client Development
IRONCLIW_SHARE_PROFILE = ai.ironcliw.client.share Development

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"
