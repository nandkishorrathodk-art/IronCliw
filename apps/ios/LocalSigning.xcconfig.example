// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

IRONCLIW_CODE_SIGN_STYLE = Automatic
IRONCLIW_DEVELOPMENT_TEAM = YOUR_TEAM_ID

IRONCLIW_APP_BUNDLE_ID = ai.ironcliw.client
IRONCLIW_SHARE_BUNDLE_ID = ai.ironcliw.client.share
IRONCLIW_ACTIVITY_WIDGET_BUNDLE_ID = ai.ironcliw.client.activitywidget
IRONCLIW_WATCH_APP_BUNDLE_ID = ai.ironcliw.client.watchkitapp
IRONCLIW_WATCH_EXTENSION_BUNDLE_ID = ai.ironcliw.client.watchkitapp.extension

// Leave empty with automatic signing.
IRONCLIW_APP_PROFILE =
IRONCLIW_SHARE_PROFILE =
