{
    "name":  "@ironcliw/mattermost",
    "version":  "2026.0.01",
    "description":  "Ironcliw Mattermost channel plugin",
    "type":  "module",
    "dependencies":  {
                         "ws":  "^8.19.0",
                         "zod":  "^4.3.6"
                     },
    "Ironcliw":  {
                     "extensions":  [
                                        "./index.ts"
                                    ],
                     "channel":  {
                                     "id":  "mattermost",
                                     "label":  "Mattermost",
                                     "selectionLabel":  "Mattermost (plugin)",
                                     "docsPath":  "/channels/mattermost",
                                     "docsLabel":  "mattermost",
                                     "blurb":  "self-hosted Slack-style chat; install the plugin to enable.",
                                     "order":  65
                                 },
                     "install":  {
                                     "npmSpec":  "@ironcliw/mattermost",
                                     "localPath":  "extensions/mattermost",
                                     "defaultChoice":  "npm"
                                 }
                 }
}
