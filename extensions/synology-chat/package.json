{
    "name":  "@ironcliw/synology-chat",
    "version":  "2026.0.01",
    "description":  "Synology Chat channel plugin for Ironcliw",
    "type":  "module",
    "dependencies":  {
                         "zod":  "^4.3.6"
                     },
    "Ironcliw":  {
                     "extensions":  [
                                        "./index.ts"
                                    ],
                     "channel":  {
                                     "id":  "synology-chat",
                                     "label":  "Synology Chat",
                                     "selectionLabel":  "Synology Chat (Webhook)",
                                     "docsPath":  "/channels/synology-chat",
                                     "docsLabel":  "synology-chat",
                                     "blurb":  "Connect your Synology NAS Chat to Ironcliw with full agent capabilities.",
                                     "order":  90
                                 },
                     "install":  {
                                     "npmSpec":  "@ironcliw/synology-chat",
                                     "localPath":  "extensions/synology-chat",
                                     "defaultChoice":  "npm"
                                 }
                 }
}
